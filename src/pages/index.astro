---
import { Image } from "@astrojs/image/components";
import Logo from "../components/Logo.astro";
import Navigation from "../components/Navigation.astro";
---

<meta charset="UTF-8" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="shortcut icon" href="images/logo.svg" />
<title>Document</title>
<link rel="stylesheet" href="styles/main.css" />

<body class="bg-background text-paragraph font-roboto">
  <div class="mx-auto max-w-5xl px-5 space-y-6 mb-6">
    <!-- HEADER -->
    <header class="flex justify-between relative">
      <!-- LOGO -->
      <Logo />
      <!-- NAV -->
      <Navigation />
    </header>
    <!-- CONTENT -->
    <main class="space-y-6">
      <!-- CTA -->
      <section class="max-w-md mx-auto text-center space-y-6">
        <h1 class="font-bold text-3xl text-headline">
          Хотите свой собственный сайт?
        </h1>
        <p>
          Нам необходимо с Вами просто познакомиться. Для этого надо будет
          нажать на кнопку “Оставить заявку” и заполнить форму. Вам останется
          только подождать, пока я не отправлю письмо с ответом, в котором
          отвечу на Ваши вопросы и предложения.
        </p>
        <button class="bg-button text-button-text px-6 py-3 rounded"
          >Оставить заявку</button
        >
      </section>

      <!-- BLOG -->
      <section class="space-y-6">
        <!-- FIRST CARD -->
        <article class="bg-background-secondary flex gap-6 flex-wrap">
          <Image
            class={"flex-1 aspect-auto object-cover"}
            src={"/images/mazda-rx7.jpg"}
            alt=""
            width={720}
            height={465}
            background={"#94A1B2"}
          />
          <div class="space-y-6 px-2 mb-6 mt-0 sm:mt-6 flex-1 min-w-[200px]">
            <h3 class="text-headline text-2xl font-bold">
              Роторная легенда Mazda RX-7
            </h3>
            <time datetime="2020-02-16" class="inline">16 февраля 2022</time>
            <p>
              Среди серий японского спорткара Mazda RX-7 FD3особо ценится третье
              поколение. Машины этой серии выпускались с 1991 г. В период между
              1993 и 1999 гг. они подверглись пяти модификациям. Это были
              первые, серийные автомобили с двойным последовательным
              турбонаддувом. Он идеально дополнял легкий роторный мотор.
            </p>
          </div>
        </article>
        <!-- OTHER CARDS -->
        <div class="flex gap-6 flex-wrap">
          <!-- #2 CARD -->
          <article class="flex-1 bg-background-secondary flex gap-6 flex-wrap">
            <Image
              class={"flex-1 aspect-auto object-cover"}
              src={"/images/toyota-mark-II.jpg"}
              alt=""
              width={720}
              height={465}
              background={"#94A1B2"}
            />
            <div class="space-y-6 px-2 mb-6 mt-0 sm:mt-6 flex-1 min-w-[200px]">
              <h3 class="text-headline text-2xl font-bold">
                Toyota Mark II для дрифта
              </h3>
              <time datetime="2020-02-16" class="inline">16 февраля 2022</time>
              <p>
                Серия Toyota Mark II пополнила список легендарных автомобилей
                Японии 90-х благодаря турбированным модификациям седьмого
                поколения, выпускаемого с 1992 по 1996 год, а также восьмого
                1996-2000 год производства. Особую популярность получили дрифт
                кары Toyota Mark II JZX-100 и JZX-90, которые и сейчас
                пользуются спросом среди автолюбителей.
              </p>
            </div>
          </article>
          <!-- #3 CARD -->
          <article class="flex-1 bg-background-secondary flex gap-6 flex-wrap">
            <Image
              class={"flex-1 aspect-auto object-cover"}
              src={"/images/nissan-240sx.png"}
              alt=""
              width={720}
              height={465}
              background={"#94A1B2"}
            />
            <div class="space-y-6 px-2 mb-6 mt-0 sm:mt-6 flex-1 min-w-[200px]">
              <h3 class="text-headline text-2xl font-bold">
                Стильный Nissan 240SX
              </h3>
              <time datetime="2020-02-16" class="inline">16 февраля 2022</time>
              <p>
                В 90-х наибольшую популярность получило спортивное купе Nissan
                240SX шестого поколения, выпускаемое в период с 1993 по 2000
                год. Серия отличалась круглыми формами с чертами агрессивного
                спортивного автомобиля, рассчитанного на тех, кто предпочитает
                активный образ жизни. Стильное купе можно увидеть в фильме
                «Форсаж-4».
              </p>
            </div>
          </article>
        </div>
      </section>

      <!-- WORKS -->
      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 md:grid-cols-4">
        <Image
          class={"w-full aspect-auto object-cover"}
          aspectRatio={1 / 1}
          width={720}
          src="/images/nektar.png"
          alt=""
        />
        <Image
          class={"w-full aspect-auto object-cover"}
          aspectRatio={1 / 1}
          width={720}
          src="/images/globals.png"
          alt=""
        />
        <Image
          class={"w-full aspect-auto object-cover"}
          aspectRatio={1 / 1}
          width={720}
          src="/images/gkp5.png"
          alt=""
        />
        <Image
          class={"w-full aspect-auto object-cover"}
          aspectRatio={1 / 1}
          width={720}
          src="/images/nektar.png"
          alt=""
        />
      </div>

      <!-- FEEDBACK -->
      <section class="flex gap-6 flex-wrap">
        <Image
          class={"flex-auto aspect-auto object-cover w-80"}
          src={"/images/code.png"}
          alt="Code"
          width={720}
          aspectRatio={16 / 9}
        />
        <form class="flex-1 flex flex-col gap-6 min-w-[320px]">
          <h2 class="font-bold text-3xl text-headline">Форма обратной связи</h2>
          <input
            class={"w-full bg-background-secondary px-6 py-3 rounded-lg"}
            placeholder="Введите ФИО"
            type="text"
          />
          <input
            class="w-full bg-background-secondary px-6 py-3 rounded-lg"
            placeholder="Введите почту"
            type="text"
          />
          <textarea
            class="w-full bg-background-secondary px-6 py-3 rounded-lg resize-none"
            placeholder="Задайте свой вопрос или оставьте своё предложение"
            rows="5"></textarea>
          <div class="flex justify-center">
            <button
              class="bg-button text-button-text px-6 py-3 rounded"
              type="submit">Оставить заявку</button
            >
          </div>
        </form>
      </section>

      <!-- CASES -->

      <section class="flex flex-wrap gap-6">
        <!-- #1 CASE -->
        <div
          class="flex-1 flex justify-around items-center gap-2 bg-background-secondary rounded-lg px-2 py-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="w-20 h-20"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
            ></path>
          </svg>

          <div class="flex flex-col">
            <span class="font-bold text-headline text-2xl">&gt; 1.5</span>
            <span>лет работы</span>
          </div>
        </div>

        <!-- #2 CASE -->
        <div
          class="flex-1 flex justify-around items-center gap-2 bg-background-secondary rounded-lg px-2 py-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="w-20 h-20"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.048 8.287 8.287 0 0 0 9 9.6a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48z"
            ></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 18a3.75 3.75 0 0 0 .495-7.467 5.99 5.99 0 0 0-1.925 3.546 5.974 5.974 0 0 1-2.133-1A3.75 3.75 0 0 0 12 18z"
            ></path>
          </svg>

          <div class="flex flex-col">
            <span class="font-bold text-headline text-2xl">&#8734;</span>
            <span>желание работать</span>
          </div>
        </div>

        <!-- #3 CASE -->
        <div
          class="flex-1 flex justify-around items-center gap-2 bg-background-secondary rounded-lg px-2 py-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="w-20 h-20"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418"
            ></path>
          </svg>

          <div class="flex flex-col">
            <span class="font-bold text-headline text-2xl">4</span>
            <span>готовых сайтов</span>
          </div>
        </div>

        <!-- #4 CASE -->
        <div
          class="flex-1 flex justify-around items-center gap-2 bg-background-secondary rounded-lg px-1 py-6"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            class="w-20 h-20"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"
            ></path>
          </svg>

          <div class="flex flex-col">
            <span class="font-bold text-headline text-2xl">7</span>
            <span>проектов на Github</span>
          </div>
        </div>
      </section>
    </main>
  </div>

  <!-- FOOTER -->
  <footer
    class="flex flex-col-reverse items-center gap-4 sm:flex-row justify-between"
  >
    <Logo />
    <div class="flex gap-4">
      <svg
        class="w-8 h-8"
        viewBox="0 0 32 32"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M16.0062 8.81245C12.0312 8.81245 8.82499 12.0187 8.82499 15.9937C8.82499 19.9687 12.0312 23.1749 16.0062 23.1749C19.9812 23.1749 23.1875 19.9687 23.1875 15.9937C23.1875 12.0187 19.9812 8.81245 16.0062 8.81245ZM16.0062 20.6625C13.4375 20.6625 11.3375 18.5687 11.3375 15.9937C11.3375 13.4187 13.4312 11.325 16.0062 11.325C18.5812 11.325 20.675 13.4187 20.675 15.9937C20.675 18.5687 18.575 20.6625 16.0062 20.6625ZM25.1562 8.5187C25.1562 9.44995 24.4062 10.1937 23.4812 10.1937C22.55 10.1937 21.8062 9.4437 21.8062 8.5187C21.8062 7.5937 22.5562 6.8437 23.4812 6.8437C24.4062 6.8437 25.1562 7.5937 25.1562 8.5187ZM29.9125 10.2187C29.8062 7.97495 29.2937 5.98745 27.65 4.34995C26.0125 2.71245 24.025 2.19995 21.7812 2.08745C19.4687 1.9562 12.5375 1.9562 10.225 2.08745C7.98749 2.1937 5.99999 2.7062 4.35624 4.3437C2.71249 5.9812 2.20624 7.9687 2.09374 10.2125C1.96249 12.525 1.96249 19.4562 2.09374 21.7687C2.19999 24.0124 2.71249 26 4.35624 27.6375C5.99999 29.275 7.98124 29.7875 10.225 29.9C12.5375 30.0312 19.4687 30.0312 21.7812 29.9C24.025 29.7937 26.0125 29.2812 27.65 27.6375C29.2875 26 29.8 24.0124 29.9125 21.7687C30.0437 19.4562 30.0437 12.5312 29.9125 10.2187ZM26.925 24.25C26.4375 25.475 25.4937 26.4187 24.2625 26.9125C22.4187 27.6437 18.0437 27.475 16.0062 27.475C13.9687 27.475 9.58749 27.6375 7.74999 26.9125C6.52499 26.425 5.58124 25.4812 5.08749 24.25C4.35624 22.4062 4.52499 18.0312 4.52499 15.9937C4.52499 13.9562 4.36249 9.57495 5.08749 7.73745C5.57499 6.51245 6.51874 5.5687 7.74999 5.07495C9.59374 4.3437 13.9687 4.51245 16.0062 4.51245C18.0437 4.51245 22.425 4.34995 24.2625 5.07495C25.4875 5.56245 26.4312 6.5062 26.925 7.73745C27.6562 9.5812 27.4875 13.9562 27.4875 15.9937C27.4875 18.0312 27.6562 22.4125 26.925 24.25Z"
        ></path>
      </svg>

      <svg
        class="w-8 h-8"
        viewBox="0 0 32 32"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M25.8062 6.06875C23.1875 3.44375 19.7 2 15.9937 2C8.34375 2 2.11875 8.225 2.11875 15.875C2.11875 18.3188 2.75625 20.7062 3.96875 22.8125L2 30L9.35625 28.0688C11.3813 29.175 13.6625 29.7563 15.9875 29.7563H15.9937C23.6375 29.7563 30 23.5312 30 15.8813C30 12.175 28.425 8.69375 25.8062 6.06875ZM15.9937 27.4188C13.9187 27.4188 11.8875 26.8625 10.1187 25.8125L9.7 25.5625L5.3375 26.7062L6.5 22.45L6.225 22.0125C5.06875 20.175 4.4625 18.0562 4.4625 15.875C4.4625 9.51875 9.6375 4.34375 16 4.34375C19.0812 4.34375 21.975 5.54375 24.15 7.725C26.325 9.90625 27.6625 12.8 27.6562 15.8813C27.6562 22.2438 22.35 27.4188 15.9937 27.4188ZM22.3188 18.7812C21.975 18.6063 20.2688 17.7688 19.95 17.6562C19.6313 17.5375 19.4 17.4812 19.1688 17.8312C18.9375 18.1812 18.275 18.9563 18.0688 19.1938C17.8688 19.425 17.6625 19.4562 17.3188 19.2812C15.2812 18.2625 13.9438 17.4625 12.6 15.1562C12.2438 14.5437 12.9562 14.5875 13.6187 13.2625C13.7312 13.0312 13.675 12.8313 13.5875 12.6562C13.5 12.4812 12.8063 10.775 12.5188 10.0813C12.2375 9.40625 11.95 9.5 11.7375 9.4875C11.5375 9.475 11.3062 9.475 11.075 9.475C10.8438 9.475 10.4688 9.5625 10.15 9.90625C9.83125 10.2563 8.9375 11.0938 8.9375 12.8C8.9375 14.5063 10.1813 16.1563 10.35 16.3875C10.525 16.6188 12.7937 20.1187 16.275 21.625C18.475 22.575 19.3375 22.6562 20.4375 22.4937C21.1063 22.3937 22.4875 21.6562 22.775 20.8438C23.0625 20.0312 23.0625 19.3375 22.975 19.1938C22.8938 19.0375 22.6625 18.95 22.3188 18.7812Z"
        ></path>
      </svg>

      <svg
        class="w-8 h-8"
        viewBox="0 0 32 32"
        fill="currentColor"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M29.9187 6.16244L25.6937 26.0874C25.375 27.4937 24.5437 27.8437 23.3625 27.1812L16.925 22.4374L13.8187 25.4249C13.475 25.7687 13.1875 26.0562 12.525 26.0562L12.9875 19.4999L24.9187 8.71869C25.4375 8.25619 24.8062 7.99994 24.1125 8.46244L9.36249 17.7499L3.01249 15.7624C1.63124 15.3312 1.60624 14.3812 3.29999 13.7187L28.1375 4.14994C29.2875 3.71869 30.2937 4.40619 29.9187 6.16244Z"
        ></path>
      </svg>
    </div>
  </footer>
</body>
