---
interface Props {
  date: Date | string;
  class?: string;
}

const props = Astro.props;

const parseDate = new Date(props.date);
const outputDate = new Intl.DateTimeFormat("ru-RU").format(parseDate.getTime());
const datetime = parseDate.toString();
---

<time class={props["class"]} datetime={datetime}>{outputDate}</time>
