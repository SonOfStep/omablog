<script>
  function uncheckTogglerMenu() {
    const toggler = document.querySelector("#toggler");
    if (toggler instanceof HTMLInputElement) {
      toggler.checked = toggler.checked && false;
    }
  }

  window.onresize = uncheckTogglerMenu;
</script>
<!-- NAVIGATION -->
<nav class="">
  <!-- BUTTON TOGGLER -->
  <label for="toggler" class="block cursor-pointer sm:hidden">
    <button class="bg-button text-button-text p-3 rounded pointer-events-none">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        class="w-6 h-6"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </label>
  <!-- CHECKBOX TOGGLER -->
  <input class="peer sr-only" type="checkbox" name="toggler" id="toggler" />
  <!-- MENU -->
  <div
    id="menu"
    class="hidden peer-checked:flex peer-checked:absolute peer-checked:inset-x-0 peer-checked:top-full peer-checked:py-4 sm:flex sm:flex-row items-center gap-4 flex-col p-0"
  >
    <ul class="flex items-center gap-4 flex-col sm:flex-row">
      <li><a href="#">Главная</a></li>
      <li><a href="#">Блог</a></li>
      <li><a href="#">Обо мне</a></li>
      <li><a href="#">Обратная связь</a></li>
    </ul>
    <button class="bg-button text-button-text p-3 rounded">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 20 20"
        class="w-6 h-6"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M18.354 13.354A9 9 0 0 1 6.646 1.646 9.003 9.003 0 0 0 10 19a9.003 9.003 0 0 0 8.354-5.646Z"
        ></path>
      </svg>
    </button>
  </div>
</nav>
