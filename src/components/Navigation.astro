---
import ThemeToggle from "./ThemeToggle";
---

<script>
  function toggleMode() {
    const isDark = localStorage.getItem("theme") !== "light";
    isDark && document.documentElement.classList.add("dark");
    !isDark && document.documentElement.classList.remove("dark");
  }

  toggleMode();
</script>

<script>
  function uncheckTogglerMenu() {
    const toggler = document.querySelector("#toggler");
    if (toggler instanceof HTMLInputElement) {
      toggler.checked = toggler.checked && false;
    }
  }

  window.onresize = uncheckTogglerMenu;
</script>

<!-- NAVIGATION -->
<nav class="">
  <!-- BUTTON TOGGLER -->
  <label for="toggler" class="block cursor-pointer sm:hidden">
    <button
      class="bg-button text-button-text dark:bg-light-button p-3 rounded pointer-events-none"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        class="w-6 h-6"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </label>
  <!-- CHECKBOX TOGGLER -->
  <input class="peer sr-only" type="checkbox" name="toggler" id="toggler" />
  <!-- MENU -->
  <div
    id="menu"
    class="hidden peer-checked:flex peer-checked:absolute peer-checked:inset-x-0 peer-checked:top-full peer-checked:py-4 sm:flex sm:flex-row items-center gap-4 flex-col p-0 bg-background dark:bg-light-background sm:bg-none"
  >
    <ul class="flex items-center gap-4 flex-col sm:flex-row">
      <li><a href="#">Главная</a></li>
      <li><a href="#">Блог</a></li>
      <li><a href="#">Обо мне</a></li>
      <li><a href="#">Обратная связь</a></li>
    </ul>
    <ThemeToggle client:load />
  </div>
</nav>
